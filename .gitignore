# ============================================================================
# ENVIRONMENT & SECRETS - CRITICAL: DO NOT COMMIT
# ============================================================================
.env                          # Local environment variables with OAuth secrets
.env.local                    # Local environment overrides
.env.*.local                  # Other local env files
.env.example                  # (exception: template only, safe to commit)

# ============================================================================
# PYTHON
# ============================================================================
__pycache__/                  # Python bytecode
*.py[cod]                     # Python compiled files
*$py.class                    # Python class files
*.so                          # Python C extensions
.Python                       # Python installation marker
build/                        # Python build directory
develop-eggs/                 # Setuptools development eggs
dist/                         # Distribution directory
downloads/                    # Downloads directory
eggs/                         # Eggs directory
.eggs/                        # Eggs marker
lib/                          # Library directory
lib64/                        # 64-bit library directory
parts/                        # Parts directory
sdist/                        # Source distribution
var/                          # Variable directory
wheels/                       # Wheels directory
share/python-wheels/          # Python wheels
*.egg-info/                   # Egg info directories
.installed.cfg               # Installed configuration
*.egg                        # Egg files
MANIFEST                     # Distribution manifest

# Virtual Environments
.venv                        # Virtual environment
venv/                        # Virtual environment
ENV/                         # Virtual environment
env/                         # Virtual environment
.env.venv                    # Virtual environment
pip-log.txt                  # Pip log file
pip-delete-this-directory.txt # Pip cleanup marker

# ============================================================================
# NODE.JS / REACT / FRONTEND
# ============================================================================
node_modules/                # Node dependencies
npm-debug.log*               # NPM debug logs
yarn-debug.log*              # Yarn debug logs
yarn-error.log*              # Yarn error logs
lerna-debug.log*             # Lerna debug logs
package-lock.json            # NPM lock file (prefer yarn.lock or leave unfixed)
yarn.lock                    # Yarn lock file
coverage/                    # Test coverage reports
dist/                        # Distribution build
build/                       # Build output
frontend/build/              # React build output

# ============================================================================
# REDIS & DATABASE
# ============================================================================
dump.rdb                     # Redis dump file
*.rdb                        # Redis database files
.redis-cli.history          # Redis CLI history

# ============================================================================
# TESTING & COVERAGE
# ============================================================================
.pytest_cache/               # Pytest cache
.coverage                    # Coverage data
htmlcov/                     # HTML coverage reports
.tox/                        # Tox test environments
.hypothesis/                 # Hypothesis test data

# ============================================================================
# IDE & EDITOR
# ============================================================================
.vscode/                     # VSCode settings
.idea/                       # JetBrains IDE
*.swp                        # Vim swap files
*.swo                        # Vim swap files
*~                           # Backup files
.sublime-project             # Sublime project files
.sublime-workspace           # Sublime workspace
.project                     # Eclipse project
.pydevproject               # PyDev project
.settings/                  # Eclipse settings
*.sublime-settings          # Sublime settings

# ============================================================================
# MACOS
# ============================================================================
.DS_Store                   # macOS folder metadata
.AppleDouble                # macOS file metadata
.LSOverride                 # macOS file metadata
._*                         # macOS resource fork
.Spotlight-V100             # macOS Spotlight index
.Trashes                    # macOS trash
*.swp                       # macOS swap files

# ============================================================================
# WINDOWS
# ============================================================================
Thumbs.db                   # Windows thumbnail cache
ehthumbs.db                 # Windows thumbnail cache
Desktop.ini                 # Windows directory settings
$RECYCLE.BIN/               # Windows recycle bin

# ============================================================================
# TEMPORARY & LOG FILES
# ============================================================================
*.log                       # All log files
*.logs                      # Log files
*.tmp                       # Temporary files
*.bak                       # Backup files
*.backup                    # Backup files
*.swp                       # Swap files
*.swo                       # Swap files
*.swn                       # Swap files
*~                          # Temporary files
.DS_Store                   # macOS metadata

# ============================================================================
# OPERATING SYSTEM
# ============================================================================
.DS_Store                   # macOS
.DS_Store?                  # macOS
._*                         # macOS
.Spotlight-V100             # macOS Spotlight
.Trashes                    # macOS Trash

# ============================================================================
# ASSIGNMENT & DOCUMENTATION
# ============================================================================
*.pdf                       # Assignment PDFs and documents
assignment/                 # Assignment folder
Assignment/                 # Assignment folder (case variation)
Thumbs.db                   # Windows
ehthumbs.db                 # Windows

# ============================================================================
# MISCELLANEOUS
# ============================================================================
.git/                       # Git metadata (exception: tracked)
.gitmodules                 # Git submodules config
*.vsix                      # VS Code extension files
*.rar                       # RAR archives
*.zip                       # ZIP archives
*.tar.gz                    # TAR archives
*.iso                       # ISO images
.vscode-server/             # VSCode server files

# ============================================================================
# PROJECT SPECIFIC
# ============================================================================
dump.rdb                    # Redis persistence file
*.db                        # Database files
*.sqlite                    # SQLite databases
.kiro/                      # Kiro framework files
Integrations_Technical_Assessment_Instructions.pdf  # Assessment file
